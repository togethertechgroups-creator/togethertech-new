datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Service {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  shortDescription String
  fullDescription  String
  image            String
  features         String   // Comma-separated or JSON string
  status           String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt        DateTime @default(now())
}

model Portfolio {
  id           String   @id @default(uuid())
  projectName  String
  clientName   String
  category     String   // Websites, Apps, Software, UI/UX, Logo, Posters
  image        String
  description  String
  technologies String   // Comma-separated values
  projectLink  String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
}

model Package {
  id            String   @id @default(uuid())
  packageName   String
  price         String
  description   String
  features      String   // Comma-separated values
  isRecommended Boolean  @default(false)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  photo       String
  bio         String
  skills      String   // Comma-separated values
  socialLinks String   // JSON string of platforms and links
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
}

model Blog {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  image          String
  content        String
  category       String
  seoTitle       String?
  seoDescription String?
  status         String   @default("PUBLISHED") // DRAFT, PUBLISHED
  createdAt      DateTime @default(now())
}

model Testimonial {
  id           String   @id @default(uuid())
  clientName   String
  businessName String
  review       String
  rating       Int      @default(5)
  photo        String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
}

model Enquiry {
  id              String   @id @default(uuid())
  name            String
  mobile          String
  email           String
  businessName    String?
  requiredService String
  budget          String
  message         String
  status          String   @default("NEW") // NEW, CONTACTED, IN_PROGRESS, CONVERTED, CLOSED
  createdAt       DateTime @default(now())
}

model Settings {
  id             String @id @default("global")
  companyName    String @default("Together Tech")
  phone          String @default("+91 98765 43210")
  email          String @default("togethertechgroups@gmail.com")
  whatsapp       String @default("+91 98765 43210")
  address        String @default("123 Tech Park, India")
  logo           String @default("/images/logo.svg")
  socialLinks    String @default("{}") // JSON string
  seoTitle       String @default("Together Tech | Your Growth, Our Technology")
  seoDescription String @default("We create professional websites, mobile apps, custom software, branding, SEO, and digital marketing solutions.")
}

model PdfFile {
  id        String   @id @default(uuid())
  name      String
  data      String   // Store base64 string
  createdAt DateTime @default(now())
}

model BillingCustomer {
  id        String   @id
  name      String
  tier      String
  gstin     String
  email     String
  phone     String
  status    String   @default("ACTIVE")
  spend     Float    @default(0.0)
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BillingDocument {
  id              String   @id
  client          String
  type            String   // "Invoice" or "Quotation"
  date            String
  dueDate         String
  status          String   // "PAID", "UNPAID", "DRAFT", etc.
  amount          Float
  gstPercent      Float    @default(0.0)
  discountPercent Float    @default(0.0)
  billingAddress  String
  lineItems       String   // JSON string of array of items
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BillingPayment {
  id           String   @id
  invoiceId    String
  customerId   String
  customerName String
  date         String
  amount       Float
  mode         String
  reference    String
  notes        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BillingSettings {
  id           String   @id @default("billing-settings")
  businessName String   @default("Together Tech")
  gstin        String   @default("27AAACF4582G1ZX")
  address      String   @default("Suite 405, Tech Plaza, Financial District,\nSan Francisco, CA 94105")
  website      String   @default("togethertechgroups.in")
  email        String   @default("togethertechgroups@gmail.com")
  phone        String   @default("+91 90475 49682")
  accountNum   String   @default("8829 4410 2293")
  swift        String   @default("BNKUS00129")
  branch       String   @default("Global Business Center")
  brandColor   String   @default("#8ec63f")
  signatures   String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
